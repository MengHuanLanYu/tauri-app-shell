{
  "name": "tauri-app-shell",
  "version": "0.1.0",
  "description": "Transparent custom titlebar + flexible multi-column layout shell for Tauri 2.0 + React",
  "keywords": [
    "tauri",
    "tauri2",
    "react",
    "titlebar",
    "layout",
    "shell"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm build",
    "release": "bash scripts/release.sh"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@tauri-apps/api": ">=2",
    "lucide-react": ">=0.300.0"
  },
  "devDependencies": {
    "@types/react": "^18",
    "tsup": "^8",
    "typescript": "^5"
  }
}
